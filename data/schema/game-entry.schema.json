{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omg-central.local/schema/game-entry.schema.json",
  "title": "GameEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "url",
    "embed_type",
    "thumbnail",
    "genre",
    "tags",
    "source_repo",
    "license",
    "playable_status",
    "added_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "format": "uri" },
    "embed_type": {
      "type": "string",
      "enum": ["iframe", "external", "download"]
    },
    "thumbnail": { "type": "string", "format": "uri-reference" },
    "genre": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_repo": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "playable_status": {
      "type": "string",
      "enum": ["playable", "broken", "requires-plugin", "unknown"]
    },
    "added_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "controls": {
      "type": "array",
      "items": { "type": "string" }
    },
    "multiplayer": {
      "type": "string",
      "enum": ["singleplayer", "local-multiplayer", "online-multiplayer"]
    }
  }
}
